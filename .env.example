# ─────────────────────────────────────────────────────────────────────────────
# Task Manager API — Environment Variables
#
# SETUP:
#   cp .env.example .env
#   # Fill in your values below
#   # NEVER commit .env to git — it is in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (Neon) ─────────────────────────────────────────────────────────
# Format: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/taskdb?sslmode=require

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Format: rediss://default:TOKEN@hostname.upstash.io:6380
REDIS_URL=rediss://default:your_upstash_token@your-db.upstash.io:6380

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for API requests.
# Leave blank to allow all origins (only safe in development).
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=
